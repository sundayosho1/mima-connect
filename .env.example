APP_NAME="MiMa Connect"
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://mimaconnect.canmpef.com
APP_TIMEZONE=Africa/Lagos
APP_LOCALE=en

# Database Configuration (cPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=canmpefc_mima_staging
DB_USERNAME=canmpefc_mima_dev
DB_PASSWORD=01mImA@02123...

# Secondary Database (if needed for multi-tenancy)
DB_HOST_SECONDARY=127.0.0.1
DB_PORT_SECONDARY=3306

# Cache & Session (File-based for cPanel shared hosting)
CACHE_DRIVER=file
CACHE_PREFIX=mima_
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=mimaconnect.canmpef.com

# Queue (Database for cPanel - no Redis needed initially)
QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=90

# Mail (Configure with cPanel email or external)
MAIL_MAILER=smtp
MAIL_HOST=mail.canmpef.com
MAIL_PORT=587
MAIL_USERNAME=noreply@mimaconnect.canmpef.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mimaconnect.canmpef.com
MAIL_FROM_NAME="${APP_NAME}"

# File Storage
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3

# AWS S3 (Future production use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Payment Gateways (Test Keys for Staging)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYSTACK_PAYMENT_URL=https://api.paystack.co

FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxx
FLUTTERWAVE_ENVIRONMENT=staging

# Termii SMS
TERMII_API_KEY=
TERMII_SENDER_ID=MiMaHomes
TERMII_BASE_URL=https://api.ng.termii.com/api

# Google Maps (for property locations)
GOOGLE_MAPS_API_KEY=

# Security
BCRYPT_ROUNDS=12
APP_CIPHER=AES-256-CBC

# Logging
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

# Maintenance Mode
MAINTENANCE_DRIVER=file
